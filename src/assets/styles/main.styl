*, *::before, *::after
  box-sizing: border-box

*
    margin: 0
    padding: 0

body
    background-color: #0F172A
    
.garage-container
    display: flex
    flex-direction: column
    align-items: center
    padding: 0.5rem

h1
    font-family: Arial, Helvetica, sans-serif
    font-size: 1.75rem
    letter-spacing: 0.02em
    margin-block: 1em
    color: #38BDF8
    

.garage-floor
    display: flex
    align-items: center
    justify-content: center
    flex-wrap: wrap
    gap: 1.25rem
    padding: 2rem
    background-color: #1E293B
    border-width: 3px
    border-color: #475569
    border-style: solid
    border-radius: 6px
    max-width: 800px

.parking-spot
    display: flex
    justify-content: center
    align-items: center 
    background-color: #334155
    border-width: 1px
    border-color: orange
    border-style: dashed
    border-radius: 3px
    width: 120px
    height: auto
    aspect-ratio: 7/5

.car
    font-size: 35px
